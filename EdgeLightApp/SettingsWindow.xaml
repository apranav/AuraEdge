<Window x:Class="EdgeLightApp.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AuraEdge"
        Width="4"
        SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="True"
        ResizeMode="NoResize"
        Loaded="Window_Loaded"
        Deactivated="Window_Deactivated">

    <!-- ══════════════════════════════════════════════════════════════════════
         RESOURCE DICTIONARY
    ═══════════════════════════════════════════════════════════════════════ -->
    <Window.Resources>

        <!-- ▌ Shared color values ───────────────────────────────────────── -->
        <SolidColorBrush x:Key="BgBrush"       Color="#0c0c12"/>
        <SolidColorBrush x:Key="CardBrush"     Color="#13131c"/>
        <SolidColorBrush x:Key="DividerBrush"  Color="#1e1e2c"/>
        <SolidColorBrush x:Key="TextPrimary"   Color="#e2e2f0"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#6a6a88"/>
        <SolidColorBrush x:Key="AccentBrush"   Color="#6c47db"/>

        <LinearGradientBrush x:Key="AccentGradient" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#7c5ce8" Offset="0"/>
            <GradientStop Color="#3b82f6" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="AccentGradientH" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#7c5ce8" Offset="0"/>
            <GradientStop Color="#3b82f6" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="TempGradient" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#a3d5ff" Offset="0.0"/>
            <GradientStop Color="#ffffff" Offset="0.5"/>
            <GradientStop Color="#ffb347" Offset="1.0"/>
        </LinearGradientBrush>

        <!-- ▌ Section heading label ─────────────────────────────────────── -->
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="Foreground"   Value="{StaticResource AccentBrush}"/>
            <Setter Property="FontSize"     Value="10"/>
            <Setter Property="FontWeight"   Value="Bold"/>
            <Setter Property="FontFamily"   Value="Segoe UI"/>
            <Setter Property="Margin"       Value="0,0,0,6"/>
        </Style>

        <!-- ▌ Standard label ────────────────────────────────────────────── -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Margin"     Value="0,0,0,4"/>
        </Style>

        <!-- ▌ Power ToggleButton ─────────────────────────────────────────── -->
        <Style x:Key="PowerToggleStyle" TargetType="ToggleButton">
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width"           Value="56"/>
            <Setter Property="Height"          Value="28"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Track" CornerRadius="14" Background="#1c1c28">
                            <Grid>
                                <!-- OFF label -->
                                <TextBlock x:Name="OffTxt" Text="OFF" FontSize="9" FontWeight="Bold"
                                           Foreground="#6a6a88" HorizontalAlignment="Right"
                                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <!-- ON label -->
                                <TextBlock x:Name="OnTxt" Text="ON" FontSize="9" FontWeight="Bold"
                                           Foreground="White" HorizontalAlignment="Left"
                                           VerticalAlignment="Center" Margin="8,0,0,0"
                                           Visibility="Collapsed"/>
                                <!-- Thumb -->
                                <Ellipse x:Name="Thumb" Width="20" Height="20" Fill="White"
                                         HorizontalAlignment="Left" Margin="4,0,0,0">
                                    <Ellipse.RenderTransform>
                                        <TranslateTransform x:Name="ThumbSlide" X="0"/>
                                    </Ellipse.RenderTransform>
                                </Ellipse>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background"
                                        Value="{StaticResource AccentGradientH}"/>
                                <Setter TargetName="OffTxt" Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="OnTxt"  Property="Visibility" Value="Visible"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ThumbSlide"
                                                             Storyboard.TargetProperty="X"
                                                             To="28" Duration="0:0:0.18">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ThumbSlide"
                                                             Storyboard.TargetProperty="X"
                                                             To="0" Duration="0:0:0.18">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseIn"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ▌ Monitor toggle (smaller, inline) ─────────────────────────── -->
        <Style x:Key="MonitorToggleStyle" TargetType="ToggleButton">
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width"           Value="46"/>
            <Setter Property="Height"          Value="24"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Track" CornerRadius="12" Background="#1c1c28">
                            <Ellipse x:Name="Thumb" Width="18" Height="18" Fill="#4a4a60"
                                     HorizontalAlignment="Left" Margin="3,0,0,0">
                                <Ellipse.RenderTransform>
                                    <TranslateTransform x:Name="ThumbSlide" X="0"/>
                                </Ellipse.RenderTransform>
                            </Ellipse>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background"
                                        Value="{StaticResource AccentGradientH}"/>
                                <Setter TargetName="Thumb" Property="Fill" Value="White"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ThumbSlide"
                                                             Storyboard.TargetProperty="X"
                                                             To="22" Duration="0:0:0.15">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ThumbSlide"
                                                             Storyboard.TargetProperty="X"
                                                             To="0" Duration="0:0:0.15">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseIn"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ▌ Colour preset chip (inactive) ────────────────────────────── -->
        <Style x:Key="PresetBtn" TargetType="Button">
            <Setter Property="Background"      Value="#1a1a26"/>
            <Setter Property="Foreground"      Value="{StaticResource TextSecondary}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush"     Value="#2a2a3c"/>
            <Setter Property="FontSize"        Value="10"/>
            <Setter Property="Height"          Value="28"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background"  Value="#22223a"/>
                    <Setter Property="Foreground"  Value="{StaticResource TextPrimary}"/>
                    <Setter Property="BorderBrush" Value="#6c47db"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ▌ Colour preset chip (active) ──────────────────────────────── -->
        <Style x:Key="PresetBtnActive" TargetType="Button">
            <Setter Property="Background"      Value="#1e1442"/>
            <Setter Property="Foreground"      Value="#a78bfa"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush"     Value="#6c47db"/>
            <Setter Property="FontSize"        Value="10"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Height"          Value="28"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ▌ System/action button ──────────────────────────────────────── -->
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Background"      Value="#1c1c28"/>
            <Setter Property="Foreground"      Value="{StaticResource TextSecondary}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush"     Value="#2a2a3c"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Height"          Value="36"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background"  Value="#22223a"/>
                    <Setter Property="Foreground"  Value="{StaticResource TextPrimary}"/>
                    <Setter Property="BorderBrush" Value="#3b82f6"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ▌ Danger button (Quit) ──────────────────────────────────────── -->
        <Style x:Key="DangerBtn" TargetType="Button" BasedOn="{StaticResource ActionBtn}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background"  Value="#2a1020"/>
                    <Setter Property="Foreground"  Value="#f87171"/>
                    <Setter Property="BorderBrush" Value="#ef4444"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ▌ Startup checkbox ──────────────────────────────────────────── -->
        <Style x:Key="ModernCheck" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Cursor"     Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ▌ Modern Slider track ─────────────────────────────────────── -->
        <Style TargetType="Slider">
            <Setter Property="IsMoveToPointEnabled" Value="True"/>
        </Style>

    </Window.Resources>

    <!-- ══════════════════════════════════════════════════════════════════════
         SLIDE-IN ANIMATION
    ═══════════════════════════════════════════════════════════════════════ -->
    <Window.Triggers>
        <EventTrigger RoutedEvent="MouseEnter">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Width"
                                     To="300" Duration="0:0:0.28">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
        <EventTrigger RoutedEvent="MouseLeave">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Width"
                                     To="4" Duration="0:0:0.28">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseIn"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>

    <!-- ══════════════════════════════════════════════════════════════════════
         LAYOUT  (two columns: 4-px accent strip | main content)
    ═══════════════════════════════════════════════════════════════════════ -->
    <Grid ClipToBounds="True">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="4"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left accent gradient strip -->
        <Border Grid.Column="0" Background="{StaticResource AccentGradient}"
                CornerRadius="2,0,0,2"/>

        <!-- Dark card backdrop -->
        <Border Grid.Column="1" Background="{StaticResource BgBrush}"
                CornerRadius="0,12,12,0"/>

        <!-- No ScrollViewer — content auto-sizes window height via SizeToContent -->
        <StackPanel Grid.Column="1" Margin="16,14,12,14">

            <!-- ────────────────── HEADER ──────────────────────────────── -->
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="AuraEdge"
                               FontFamily="Segoe UI" FontSize="19" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimary}"/>
                    <TextBlock Text="Edge Lighting Control"
                               FontFamily="Segoe UI" FontSize="11"
                               Foreground="{StaticResource TextSecondary}"
                               Margin="0,2,0,0"/>
                </StackPanel>
                <ToggleButton x:Name="PowerBtn"
                              Grid.Column="1" VerticalAlignment="Center"
                              Style="{StaticResource PowerToggleStyle}"
                              Click="Toggle_Click"/>
            </Grid>

            <!-- Divider -->
            <Border Height="1" Background="{StaticResource DividerBrush}" Margin="0,0,0,12"/>

            <!-- ─────────────────── DISPLAYS ──────────────────────────── -->
            <TextBlock Text="D I S P L A Y S" Style="{StaticResource SectionLabel}"/>
            <StackPanel x:Name="MonitorsList" Margin="0,0,0,10"/>

            <!-- Divider -->
            <Border Height="1" Background="{StaticResource DividerBrush}" Margin="0,0,0,12"/>

            <!-- ─────────────────── APPEARANCE ────────────────────────── -->
            <TextBlock Text="A P P E A R A N C E" Style="{StaticResource SectionLabel}"/>

            <TextBlock Text="Color Temperature" Style="{StaticResource FieldLabel}"/>
            <Grid Height="26" Margin="0,0,0,6">
                <Border CornerRadius="13"
                        Background="{StaticResource TempGradient}"
                        Opacity="0.85"/>
                <Slider x:Name="TempSlider"
                        Minimum="0" Maximum="1" Value="0.5"
                        ValueChanged="TempSlider_ValueChanged"
                        Opacity="0.9" VerticalAlignment="Center"/>
            </Grid>

            <UniformGrid Rows="1" Columns="4" Margin="0,0,0,10">
                <Button x:Name="CoolBtn"    Content="❄ Cool"    Style="{StaticResource PresetBtn}" Margin="0,0,3,0" Click="CoolBtn_Click"/>
                <Button x:Name="NeutralBtn" Content="☀ Neutral" Style="{StaticResource PresetBtn}" Margin="0,0,3,0" Click="NeutralBtn_Click"/>
                <Button x:Name="WarmBtn"    Content="🍂 Warm"   Style="{StaticResource PresetBtn}" Margin="0,0,3,0" Click="WarmBtn_Click"/>
                <Button x:Name="SunsetBtn"  Content="🌅 Sunset" Style="{StaticResource PresetBtn}" Click="SunsetBtn_Click"/>
            </UniformGrid>

            <TextBlock Text="Edge Thickness" Style="{StaticResource FieldLabel}"/>
            <Slider x:Name="ThicknessSlider"
                    Minimum="10" Maximum="100" Value="100"
                    Margin="0,0,0,10"
                    ValueChanged="ThicknessSlider_ValueChanged"/>

            <!-- Brightness row: label left, DPI hint right -->
            <Grid Margin="0,0,0,4">
                <TextBlock Text="Brightness" Style="{StaticResource FieldLabel}" HorizontalAlignment="Left"/>
                <TextBlock x:Name="DpiHintText"
                           HorizontalAlignment="Right"
                           Foreground="#3a5a80"
                           FontSize="10"
                           VerticalAlignment="Bottom"/>
            </Grid>
            <Slider x:Name="OpacitySlider"
                    Minimum="0.1" Maximum="1.0" Value="1.0"
                    Margin="0,0,0,12"
                    ValueChanged="OpacitySlider_ValueChanged"/>

            <!-- Divider -->
            <Border Height="1" Background="{StaticResource DividerBrush}" Margin="0,0,0,12"/>

            <!-- ─────────────────── SYSTEM ────────────────────────────── -->
            <TextBlock Text="S Y S T E M" Style="{StaticResource SectionLabel}"/>

            <CheckBox x:Name="CameraAutoCheckBox"
                      Content="Auto-enable edge light when camera is active"
                      Style="{StaticResource ModernCheck}"
                      Margin="0,0,0,8"
                      Checked="CameraAutoCheckBox_Changed"
                      Unchecked="CameraAutoCheckBox_Changed"/>

            <CheckBox x:Name="StartupCheckBox"
                      Content="Launch at Windows startup"
                      Style="{StaticResource ModernCheck}"
                      Margin="0,0,0,8"
                      Checked="StartupCheckBox_Changed"
                      Unchecked="StartupCheckBox_Changed"/>

            <CheckBox x:Name="HotkeyCheckBox"
                      Content="Enable Alt+L hotkey to On/Off"
                      Style="{StaticResource ModernCheck}"
                      Margin="0,0,0,10"
                      Checked="HotkeyCheckBox_Changed"
                      Unchecked="HotkeyCheckBox_Changed"/>

            <Button Content="⏻  Quit App"
                    Click="Quit_Click"
                    Style="{StaticResource DangerBtn}"/>

            <!-- Footer — bright and readable -->
            <TextBlock Text="Developed by Krishna Pranav"
                       Foreground="#8080b8"
                       FontSize="10"
                       FontFamily="Segoe UI"
                       HorizontalAlignment="Center"
                       Margin="0,12,0,0"/>

        </StackPanel>
    </Grid>
</Window>
